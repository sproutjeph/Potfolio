---
import BaseLayout from '@/layouts/BaseLayout.astro';

const experience = [
  {
    company: 'Incented',
    role: 'Frontend Developer',
    location: 'Remote · United States',
    period: 'DEC 2023 — PRESENT',
    summary:
      "Lead frontend development on Permissionless Incentivization and Coordination — building intuitive UIs for the proposition, prioritization, execution, and validation phases of distributed task workflows. Translate Figma to pixel-perfect responsive UIs and own end-to-end feature delivery.",
    stack: ['Next.js 14', 'TypeScript', 'Tailwind CSS', 'Redux', 'Supabase'],
  },
  {
    company: 'STOVE',
    role: 'Frontend Developer',
    location: 'Contract · Remote · California, USA',
    period: 'AUG 2022 — NOV 2023',
    summary:
      'Shipped features for a Food Delivery App — reusable responsive components and contributing to code reviews. Co-designed and developed an Employee Dashboard focused on intuitive UX and scalable state management.',
    stack: ['Next.js', 'React', 'TypeScript', 'Tailwind CSS', 'Redux Toolkit'],
  },
  {
    company: 'Freelancer.com',
    role: 'Frontend Web Developer',
    location: 'Full-time · Enugu, Nigeria',
    period: 'JAN 2020 — AUG 2022',
    summary:
      'Delivered 10+ web projects for international clients across e-commerce, education and SaaS — independent from spec to deployment. Built reusable React component libraries and integrated REST APIs.',
    stack: ['React', 'JavaScript', 'REST APIs', 'HTML5 / CSS3'],
  },
];

const certifications = [
  'Udemy — React (Complete Guide)',
  'Udemy — TypeScript',
  'Udemy — MERN Stack',
  'Udemy — Modern JavaScript',
  'Udemy — Responsive Web Design (HTML / CSS)',
  'Google Developer Groups Cairo — Web Development',
  'freeCodeCamp — Responsive Web Design',
];
---

<BaseLayout
  title="About — Jephthah"
  description="Jephthah — founder-engineer in Abuja, building AI-native products solo."
>
  <section class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground">ABOUT / 2026</span>
      <h1
        class="font-display mt-6 max-w-5xl text-foreground"
        style="font-size: clamp(2.75rem, 9vw, 9rem); letter-spacing: -0.045em; line-height: 0.9;"
      >
        Founder-engineer.<br />
        <span style="color: var(--accent)">Abuja</span>, working globally.
      </h1>
    </div>
  </section>

  <section class="relative border-t border-border pt-16 pb-24 md:pt-24 md:pb-32">
    <div class="mx-auto grid w-full max-w-[1440px] grid-cols-12 gap-x-6 px-6 md:gap-x-10 md:px-10">
      {/* Side rail */}
      <aside class="col-span-12 md:col-span-3">
        <dl class="space-y-8 md:sticky md:top-32">
          <div>
            <dt class="eyebrow text-muted-foreground">Currently</dt>
            <dd class="mt-2 text-foreground">Abuja, Nigeria</dd>
          </div>
          <div>
            <dt class="eyebrow text-muted-foreground">Building</dt>
            <dd class="mt-2 space-y-1 text-foreground">
              <div>DeeepSolve</div>
              <div>TrackQR</div>
              <div>ComplyNG</div>
            </dd>
          </div>
          <div>
            <dt class="eyebrow text-muted-foreground">Available for</dt>
            <dd class="mt-2 text-foreground">
              Founder-engineer roles,<br />AI-native product builds,<br />serious collaboration.
            </dd>
          </div>
          <div>
            <dt class="eyebrow text-muted-foreground">CV</dt>
            <dd class="mt-2">
              <a
                href="/jephthah-cv.pdf"
                download
                class="eyebrow inline-flex items-center gap-2 border-b border-foreground/40 pb-1 text-foreground transition-colors hover:border-foreground"
              >
                Download
                <span aria-hidden="true">↓</span>
              </a>
            </dd>
          </div>
        </dl>
      </aside>

      {/* Body column */}
      <article
        class="col-span-12 mt-12 max-w-[65ch] text-lg leading-relaxed text-foreground md:col-span-8 md:col-start-5 md:mt-0 md:text-xl"
      >
        <p>
          I design, build, deploy, and operate software end-to-end. Most of what I ship is
          AI-native — products where the model is part of the runtime, not a bolt-on.
        </p>

        <p class="mt-8">
          I work solo because the products I want to ship don't exist yet, and waiting for
          someone else to build them isn't a plan. Four products live: <a
            href="/work/deeepsolve"
            class="border-b border-foreground/30 hover:border-foreground">DeeepSolve</a
          > (50K+ Nigerian students), <a
            href="/work/track-qr"
            class="border-b border-foreground/30 hover:border-foreground">TrackQR</a
          > (1M+ scans served), <a
            href="/work/complyng"
            class="border-b border-foreground/30 hover:border-foreground">ComplyNG</a
          > (continuous compliance for Nigerian startups), and <a
            href="/work/incented"
            class="border-b border-foreground/30 hover:border-foreground">Incented</a
          > (Web3 coordination infrastructure).
        </p>

        <p class="mt-8">
          Four years before the solo run, I shipped frontend for distributed teams — most
          recently leading the UI on Incented's coordination protocol, and before that
          building consumer and dashboard products at STOVE and as a freelance engineer
          out of Enugu. Everything I'm building solo now sits on that foundation.
        </p>
      </article>
    </div>
  </section>

  {/* Experience timeline */}
  <section
    id="experience"
    class="relative scroll-mt-24 border-t border-border pt-16 pb-24 md:pt-24 md:pb-32"
    data-section="experience"
  >
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        EXPERIENCE
      </span>
      <h2
        class="font-display mt-6 max-w-3xl text-foreground"
        style="font-size: clamp(2rem, 5vw, 4.5rem); letter-spacing: -0.04em; line-height: 0.95;"
        data-anim-section-heading
      >
        Where I've shipped.
      </h2>

      <ol class="mt-16 flex flex-col">
        {
          experience.map((role, i) => (
            <li
              class:list={[
                'grid grid-cols-12 gap-x-6 gap-y-4 py-10 md:gap-x-10 md:py-14',
                i === 0 ? 'border-t border-border' : '',
                'border-b border-border',
              ]}
            >
              <div class="col-span-12 md:col-span-3">
                <span class="eyebrow text-muted-foreground">{role.period}</span>
              </div>
              <div class="col-span-12 md:col-span-8 md:col-start-5">
                <h3
                  class="font-display text-foreground"
                  style="font-size: clamp(1.75rem, 4vw, 3rem); letter-spacing: -0.04em; line-height: 0.95;"
                >
                  {role.company}
                </h3>
                <p class="mt-2 text-muted-foreground">
                  {role.role} · {role.location}
                </p>
                <p class="mt-5 max-w-[65ch] text-base text-foreground md:text-lg">
                  {role.summary}
                </p>
                <ul class="mt-6 flex flex-wrap gap-2">
                  {role.stack.map((tech) => (
                    <li class="eyebrow rounded-full border border-border px-3 py-1 text-muted-foreground">
                      {tech}
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* Education + Certifications */}
  <section
    id="foundations"
    class="relative scroll-mt-24 border-t border-border py-24 md:py-32"
    data-section="foundations"
  >
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        BACKGROUND
      </span>
      <h2
        class="font-display mt-6 max-w-3xl text-foreground"
        style="font-size: clamp(2rem, 5vw, 4.5rem); letter-spacing: -0.04em; line-height: 0.95;"
        data-anim-section-heading
      >
        Foundations.
      </h2>

      <div class="mt-16 grid grid-cols-1 gap-x-10 gap-y-16 md:grid-cols-2">
        <div>
          <div class="flex items-baseline justify-between border-b border-border pb-4">
            <span class="eyebrow text-foreground">EDUCATION</span>
          </div>
          <div class="py-6">
            <h3
              class="font-display text-foreground"
              style="font-size: clamp(1.5rem, 2.5vw, 2rem); letter-spacing: -0.03em; line-height: 1.1;"
            >
              HND, Electrical / Electronics &amp; Communications Engineering
            </h3>
            <p class="mt-3 text-muted-foreground">
              Institute of Management &amp; Technology (IMT)
            </p>
            <p class="eyebrow mt-3 text-muted-foreground/80">
              SEP 2010 — OCT 2015 · DISTINCTION
            </p>
          </div>
        </div>

        <div>
          <div class="flex items-baseline justify-between border-b border-border pb-4">
            <span class="eyebrow text-foreground">CERTIFICATIONS</span>
            <span class="eyebrow text-muted-foreground/70">
              {String(certifications.length).padStart(2, '0')}
            </span>
          </div>
          <ul class="flex flex-col">
            {
              certifications.map((cert) => (
                <li class="border-b border-border py-4 text-foreground">
                  {cert}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { gsap, registerGsap, prefersReducedMotion, splitWords } from '@/lib/gsap';

    function bindAbout() {
      registerGsap();
      if (prefersReducedMotion()) return;

      const headings = document.querySelectorAll<HTMLElement>(
        '[data-section="experience"] [data-anim-section-heading], [data-section="foundations"] [data-anim-section-heading]'
      );
      headings.forEach((el) => {
        const split = splitWords(el);
        gsap.fromTo(
          split.words,
          { yPercent: 100, opacity: 0 },
          {
            yPercent: 0,
            opacity: 1,
            duration: 0.85,
            ease: 'power4.out',
            stagger: 0.05,
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
          }
        );
      });
    }

    bindAbout();
    document.addEventListener('astro:page-load', bindAbout);
  </script>
</BaseLayout>
