---
const email = 'donjeph@gmail.com';

const socials = [
  { href: 'https://github.com/sproutjeph', label: 'Github', icon: 'github' },
  { href: 'https://x.com/jephthahmbah', label: 'X / Twitter', icon: 'x' },
  { href: 'https://linkedin.com/in/jephthahmbah', label: 'LinkedIn', icon: 'linkedin' },
];
---

<section
  id="contact"
  class="relative scroll-mt-24 border-t border-border py-32 md:py-44"
  data-section="contact"
>
  <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
    <span class="eyebrow text-muted-foreground" data-anim-section>
      LET'S TALK
    </span>

    <h2
      class="font-display mt-8 text-foreground"
      style="font-size: clamp(3rem, 9vw, 9rem); letter-spacing: -0.045em; line-height: 0.88;"
      data-anim-section-heading
    >
      Let's build<br />something<span style="color: var(--accent)">.</span>
    </h2>

    <div class="mt-16 grid grid-cols-12 gap-x-6 md:gap-x-10">
      <div class="col-span-12 md:col-span-7">
        <span class="eyebrow text-muted-foreground">EMAIL</span>
        <a
          href={`mailto:${email}`}
          class="font-display group mt-3 block text-foreground transition-colors"
          style="font-size: clamp(1.5rem, 3.5vw, 3rem); letter-spacing: -0.03em; line-height: 1;"
        >
          <span class="border-b border-foreground/0 transition-colors group-hover:border-foreground">
            {email}
          </span>
        </a>
        <p class="mt-6 max-w-prose text-muted-foreground">
          Currently in Abuja, working globally. Open to founder-engineer roles,
          AI-native product builds, and serious collaboration.
        </p>
      </div>

      <div class="col-span-12 mt-12 md:col-span-5 md:mt-0">
        <span class="eyebrow text-muted-foreground">ELSEWHERE</span>
        <ul class="mt-3 flex flex-col gap-3">
          {
            socials.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between border-b border-border py-3 text-foreground transition-colors hover:border-foreground"
                >
                  <span class="font-display text-xl tracking-[-0.03em]">
                    {label}
                  </span>
                  <span class="text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap, registerGsap, prefersReducedMotion, splitWords } from '@/lib/gsap';

  function bindContact() {
    registerGsap();
    if (prefersReducedMotion()) return;
    const sec = document.querySelector('[data-section="contact"]');
    if (!sec) return;

    const heading = sec.querySelector<HTMLElement>('[data-anim-section-heading]');
    if (heading) {
      const split = splitWords(heading);
      gsap.fromTo(
        split.words,
        { yPercent: 100, opacity: 0 },
        {
          yPercent: 0,
          opacity: 1,
          duration: 0.9,
          ease: 'power4.out',
          stagger: 0.06,
          scrollTrigger: { trigger: heading, start: 'top 85%', once: true },
        }
      );
    }
  }

  bindContact();
  document.addEventListener('astro:page-load', bindContact);
</script>
