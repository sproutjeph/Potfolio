---
const stats = [
  { value: 50000, suffix: 'K+', divisor: 1000, label: 'Students reached', source: 'DeeepSolve' },
  { value: 1, suffix: 'M+', divisor: 1, label: 'QR scans served', source: 'TrackQR' },
  { value: 8, suffix: '', divisor: 1, label: 'Nigerian regulators mapped', source: 'ComplyNG' },
  { value: 4, suffix: '', divisor: 1, label: 'Products shipped solo', source: '2025—2026' },
];
---

<section
  id="stats"
  class="relative scroll-mt-24 border-t border-border py-24 md:py-32"
  data-section="stats"
>
  <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
    <div class="mb-16 max-w-3xl">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        BY THE NUMBERS
      </span>
      <h2
        class="font-display mt-6 text-foreground"
        style="font-size: clamp(2rem, 5vw, 4.5rem); letter-spacing: -0.04em; line-height: 0.95;"
        data-anim-section-heading
      >
        Real users. Real numbers.
      </h2>
    </div>

    <ul class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-4 md:gap-x-10">
      {
        stats.map((stat) => (
          <li class="flex flex-col" data-stat>
            <span
              class="font-display flex items-baseline gap-1 text-foreground"
              style="font-size: clamp(2.75rem, 6vw, 5.5rem); letter-spacing: -0.04em; line-height: 0.9;"
            >
              <span
                data-stat-counter
                data-target={stat.value}
                data-divisor={stat.divisor}
              >
                0
              </span>
              <span class="text-foreground">{stat.suffix}</span>
            </span>
            <span
              class="mt-4 max-w-[18ch] text-sm text-muted-foreground md:text-base"
            >
              {stat.label}
            </span>
            <span class="eyebrow mt-2 text-muted-foreground/70">
              {stat.source}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  import { gsap, registerGsap, prefersReducedMotion, splitWords, ScrollTrigger } from '@/lib/gsap';

  function bindStats() {
    registerGsap();
    const sec = document.querySelector('[data-section="stats"]');
    if (!sec) return;

    const heading = sec.querySelector<HTMLElement>('[data-anim-section-heading]');
    if (heading && !prefersReducedMotion()) {
      const split = splitWords(heading);
      gsap.fromTo(
        split.words,
        { yPercent: 100, opacity: 0 },
        {
          yPercent: 0,
          opacity: 1,
          duration: 0.8,
          ease: 'power4.out',
          stagger: 0.04,
          scrollTrigger: { trigger: heading, start: 'top 85%', once: true },
        }
      );
    }

    const counters = sec.querySelectorAll<HTMLElement>('[data-stat-counter]');
    counters.forEach((el) => {
      const target = Number(el.dataset.target || 0);
      const divisor = Number(el.dataset.divisor || 1);
      const format = (n: number) => {
        const v = n / divisor;
        return divisor > 1 ? String(Math.round(v)) : String(Math.round(v));
      };

      if (prefersReducedMotion()) {
        el.textContent = format(target);
        return;
      }

      const counter = { val: 0 };
      gsap.to(counter, {
        val: target,
        duration: 1.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        onUpdate() {
          el.textContent = format(counter.val);
        },
      });
    });
  }

  bindStats();
  document.addEventListener('astro:page-load', bindStats);
</script>
