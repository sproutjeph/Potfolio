---

---

<section
  id="about"
  class="relative scroll-mt-24 border-t border-border py-24 md:py-32"
  data-section="about"
>
  <div class="mx-auto grid w-full max-w-[1440px] grid-cols-12 gap-x-6 px-6 md:gap-x-10 md:px-10">
    <div class="col-span-12 md:col-span-5">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        ABOUT / 2026
      </span>
    </div>

    <div class="col-span-12 mt-6 md:col-span-7 md:mt-0">
      <p
        class="font-display text-foreground"
        style="font-size: clamp(1.75rem, 3.2vw, 2.75rem); letter-spacing: -0.03em; line-height: 1.05;"
        data-anim-section-heading
      >
        I'm a founder-engineer in Abuja, Nigeria. I build AI-native products end-to-end —
        from rules engines to React Native to on-chain primitives. I work solo because
        the products I want to ship don't exist yet, and waiting for someone else to
        build them isn't a plan.
      </p>

      <a
        href="/about"
        class="eyebrow mt-10 inline-flex items-center gap-3 text-foreground transition-opacity hover:opacity-70"
      >
        <span class="h-px w-10 bg-foreground"></span>
        More about me
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap, registerGsap, prefersReducedMotion, splitWords } from '@/lib/gsap';

  function bindAbout() {
    registerGsap();
    if (prefersReducedMotion()) return;

    const sec = document.querySelector('[data-section="about"]');
    if (!sec) return;

    const heading = sec.querySelector<HTMLElement>('[data-anim-section-heading]');
    if (heading) {
      const split = splitWords(heading);
      gsap.fromTo(
        split.words,
        { yPercent: 80, opacity: 0 },
        {
          yPercent: 0,
          opacity: 1,
          duration: 0.7,
          ease: 'power4.out',
          stagger: 0.015,
          scrollTrigger: { trigger: heading, start: 'top 85%', once: true },
        }
      );
    }
  }

  bindAbout();
  document.addEventListener('astro:page-load', bindAbout);
</script>
