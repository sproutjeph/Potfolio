---
import BaseLayout from '@/layouts/BaseLayout.astro';

type StackItem = { name: string; note?: string };

const frontend: StackItem[] = [
  { name: 'React', note: 'Default for product UIs' },
  { name: 'Next.js', note: 'App Router · my default framework' },
  { name: 'React Native', note: 'Mobile · Expo' },
  { name: 'TypeScript', note: 'Everywhere, strict mode' },
  { name: 'Redux' },
  { name: 'Tailwind CSS' },
  { name: 'shadcn/ui' },
  { name: 'React Query' },
  { name: 'HTML5' },
  { name: 'CSS3' },
];

const backend: StackItem[] = [
  { name: 'Node.js' },
  { name: 'Express.js' },
  { name: 'Bun', note: 'DeeepSolve & TrackQR runtime' },
  { name: 'REST APIs' },
  { name: 'Supabase', note: 'Postgres + auth in one' },
  { name: 'MongoDB' },
  { name: 'PostgreSQL' },
];

const tools: StackItem[] = [
  { name: 'Docker' },
  { name: 'Vercel' },
  { name: 'Fly.io', note: 'Container hosting' },
  { name: 'Cloudflare R2' },
  { name: 'Git' },
  { name: 'Claude Code', note: 'Daily driver' },
  { name: 'Lemon Squeezy', note: 'Payments & licensing' },
  { name: 'AI / LLM integration' },
  { name: 'Responsive design' },
  { name: 'Code reviews' },
  { name: 'OOP' },
];

const categories = [
  { key: 'frontend', title: 'FRONTEND', items: frontend },
  { key: 'backend', title: 'BACKEND', items: backend },
  { key: 'tools', title: 'TOOLS & PRACTICES', items: tools },
];

const inProduction = [
  {
    title: 'TrackQR',
    href: '/work/track-qr',
    outcome: '1M+ scans served.',
    stack: [
      'Next.js (App Router)',
      'TypeScript',
      'Tailwind + shadcn/ui',
      'Bun',
      'Docker',
      'MongoDB',
      'Cloudflare R2',
      'Lemon Squeezy',
      'Fly.io',
    ],
  },
  {
    title: 'DeeepSolve',
    href: '/work/deeepsolve',
    outcome: '50K+ Nigerian students · 85% self-reported pass rate.',
    stack: [
      'Next.js',
      'TypeScript',
      'React',
      'Node.js',
      'MongoDB',
      'Supabase',
      'Tailwind CSS',
      'LLM integration',
    ],
  },
];
---

<BaseLayout
  title="Skills — Jephthah"
  description="The tools and stack Jephthah ships with: TypeScript, Next.js, React Native, Node.js, and AI-native infrastructure. 4+ years across web, mobile, and backend."
>
  {/* A. Hero */}
  <section class="relative pt-24 pb-16 md:pt-32 md:pb-24" data-section="skills-hero">
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground">STACK / 2026</span>
      <h1
        class="font-display mt-6 max-w-5xl text-foreground"
        style="font-size: clamp(2.75rem, 9vw, 9rem); letter-spacing: -0.045em; line-height: 0.9;"
        data-anim-hero
      >
        Tools I ship<br />with<span style="color: var(--accent)">.</span>
      </h1>
      <p
        class="mt-10 max-w-2xl text-base text-muted-foreground md:text-lg"
      >
        4+ years shipping production web, mobile, and backend products. Mostly
        TypeScript, Next.js, and AI-native stacks — built for users in Africa
        and operated globally.
      </p>
    </div>
  </section>

  {/* B. Stack by category */}
  <section
    id="technologies"
    class="relative scroll-mt-24 border-t border-border py-24 md:py-32"
    data-section="technologies"
  >
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        TECHNOLOGIES
      </span>
      <h2
        class="font-display mt-6 max-w-3xl text-foreground"
        style="font-size: clamp(2rem, 5vw, 4.5rem); letter-spacing: -0.04em; line-height: 0.95;"
        data-anim-section-heading
      >
        What I build with.
      </h2>

      <div class="mt-16 grid grid-cols-1 gap-x-10 gap-y-16 md:grid-cols-3">
        {
          categories.map((cat) => (
            <div class="flex flex-col">
              <div class="flex items-baseline justify-between border-b border-border pb-4">
                <span class="eyebrow text-foreground">{cat.title}</span>
                <span class="eyebrow text-muted-foreground/70">
                  {String(cat.items.length).padStart(2, '0')}
                </span>
              </div>
              <ul class="flex flex-col">
                {cat.items.map((item) => (
                  <li class="border-b border-border py-5">
                    <div
                      class="font-display text-foreground"
                      style="font-size: clamp(1.5rem, 2vw, 1.875rem); letter-spacing: -0.03em; line-height: 1.05;"
                    >
                      {item.name}
                    </div>
                    {item.note && (
                      <div class="mt-1.5 text-sm text-muted-foreground">
                        {item.note}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* C. In production */}
  <section
    id="in-production"
    class="relative scroll-mt-24 border-t border-border py-24 md:py-32"
    data-section="in-production"
  >
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        IN PRODUCTION
      </span>
      <h2
        class="font-display mt-6 max-w-3xl text-foreground"
        style="font-size: clamp(2rem, 5vw, 4.5rem); letter-spacing: -0.04em; line-height: 0.95;"
        data-anim-section-heading
      >
        Where these tools live.
      </h2>

      <div class="mt-16 grid grid-cols-1 gap-x-10 gap-y-10 md:grid-cols-2">
        {
          inProduction.map((p) => (
            <a
              href={p.href}
              class="group flex flex-col border-t border-border pt-8 transition-colors hover:bg-foreground/[0.02]"
            >
              <div class="flex items-start justify-between gap-6">
                <h3
                  class="font-display text-foreground transition-opacity group-hover:opacity-90"
                  style="font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: -0.04em; line-height: 0.95;"
                >
                  {p.title}
                </h3>
                <span
                  class="mt-2 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-border-strong/20 text-foreground transition-transform duration-300 group-hover:scale-110"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    aria-hidden="true"
                  >
                    <path d="M7 17L17 7M17 7H7M17 7v10" />
                  </svg>
                </span>
              </div>
              <p class="mt-4 text-base text-muted-foreground md:text-lg">
                {p.outcome}
              </p>
              <ul class="mt-6 flex flex-wrap gap-2 pb-2">
                {p.stack.map((tech) => (
                  <li class="eyebrow rounded-full border border-border px-3 py-1 text-muted-foreground">
                    {tech}
                  </li>
                ))}
              </ul>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* D. CTA */}
  <section
    id="skills-cta"
    class="relative scroll-mt-24 border-t border-border py-24 md:py-32"
    data-section="skills-cta"
  >
    <div class="mx-auto w-full max-w-[1440px] px-6 md:px-10">
      <span class="eyebrow text-muted-foreground" data-anim-section>
        NEXT STEP
      </span>
      <h2
        class="font-display mt-6 max-w-4xl text-foreground"
        style="font-size: clamp(2.25rem, 7vw, 6rem); letter-spacing: -0.045em; line-height: 0.9;"
        data-anim-section-heading
      >
        Need a builder<br />who ships<span style="color: var(--accent)">?</span>
      </h2>

      <ul class="mt-12 flex max-w-2xl flex-col">
        <li>
          <a
            href="/work"
            class="group flex items-center justify-between border-b border-border py-5 text-foreground transition-colors hover:border-foreground"
          >
            <span
              class="font-display"
              style="font-size: clamp(1.5rem, 2.5vw, 2.25rem); letter-spacing: -0.03em;"
            >
              See all work
            </span>
            <span
              class="text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
            >
              ↗
            </span>
          </a>
        </li>
        <li>
          <a
            href="/contact"
            class="group flex items-center justify-between border-b border-border py-5 text-foreground transition-colors hover:border-foreground"
          >
            <span
              class="font-display"
              style="font-size: clamp(1.5rem, 2.5vw, 2.25rem); letter-spacing: -0.03em;"
            >
              Get in touch
            </span>
            <span
              class="text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
            >
              ↗
            </span>
          </a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap, registerGsap, prefersReducedMotion, splitWords } from '@/lib/gsap';

  function bindSkills() {
    registerGsap();
    if (prefersReducedMotion()) return;

    const headingSelectors = [
      '[data-anim-hero]',
      '[data-section="technologies"] [data-anim-section-heading]',
      '[data-section="in-production"] [data-anim-section-heading]',
      '[data-section="skills-cta"] [data-anim-section-heading]',
    ];

    headingSelectors.forEach((sel) => {
      const el = document.querySelector<HTMLElement>(sel);
      if (!el) return;
      const split = splitWords(el);
      gsap.fromTo(
        split.words,
        { yPercent: 100, opacity: 0 },
        {
          yPercent: 0,
          opacity: 1,
          duration: 0.85,
          ease: 'power4.out',
          stagger: 0.05,
          scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        }
      );
    });
  }

  bindSkills();
  document.addEventListener('astro:page-load', bindSkills);
</script>
