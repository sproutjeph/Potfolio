---
import { Download } from 'lucide-react';
---

<section
  id="hero"
  class="relative w-full overflow-hidden"
  data-section="hero"
>
  <div
    class="mx-auto grid w-full max-w-[1440px] grid-cols-12 gap-x-6 px-6 pt-6 pb-20 md:gap-x-10 md:px-10 md:pt-10 md:pb-32 lg:min-h-[calc(100vh-6rem)]"
  >
    {/* Left: text column */}
    <div class="col-span-12 flex flex-col justify-center lg:col-span-7">
      <div class="flex items-center gap-4" data-anim-init data-hero-eyebrow>
        <span class="eyebrow text-foreground">FOUNDER. ENGINEER. ABUJA.</span>
        <span class="h-px w-16 bg-foreground/30"></span>
      </div>

      <h1
        class="font-display mt-8 text-foreground"
        style="font-size: clamp(3rem, 8.5vw, 8.5rem); letter-spacing: -0.04em; line-height: 0.9;"
        data-hero-h1
      >
        I ship products at
        the edge of AI
        and <span style="color: var(--accent)">Africa</span>.
      </h1>

      <p
        class="mt-10 max-w-xl text-base text-muted-foreground md:text-lg"
        data-anim-init
        data-hero-sub
      >
        Solo-built founder-engineer in Abuja. Four AI-native products shipped — exam-prep for
        50,000+ students, dynamic QR analytics, regulatory compliance for Nigerian startups, and
        Web3 coordination infrastructure.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4" data-anim-init data-hero-cta>
        <a
          href="/jephthah-cv.pdf"
          download
          class="group inline-flex items-stretch overflow-hidden rounded-full border border-border-strong/20 bg-foreground text-background transition-transform hover:scale-[1.02]"
        >
          <span
            class="flex h-12 w-12 items-center justify-center"
            style="background: var(--accent)"
          >
            <Download className="h-4 w-4 text-white" />
          </span>
          <span
            class="flex items-center px-6 text-xs font-medium uppercase"
            style="letter-spacing: var(--tracking-eyebrow)"
          >
            Download CV
          </span>
        </a>

        <a
          href="/work"
          class="eyebrow group inline-flex items-center gap-2 px-2 py-3 text-foreground transition-opacity hover:opacity-70"
        >
          Selected work
          <span
            class="inline-block transition-transform group-hover:translate-x-1"
            aria-hidden="true">→</span
          >
        </a>
      </div>
    </div>

    {/* Right: portrait placeholder */}
    <div class="col-span-12 mt-12 lg:col-span-5 lg:mt-0 lg:flex lg:items-center">
      <div
        class="relative ml-auto w-full max-w-[420px] overflow-hidden rounded-sm"
        style="aspect-ratio: 4/5"
        data-anim-init
        data-hero-portrait
      >
        <div
          class="absolute inset-0 flex items-center justify-center bg-foreground"
          data-parallax
        >
          <span
            class="font-display text-background"
            style="font-size: 11rem; letter-spacing: -0.06em; line-height: 1;"
          >
            JM
          </span>

          {/* film grain overlay */}
          <svg
            class="pointer-events-none absolute inset-0 h-full w-full opacity-[0.07] mix-blend-overlay"
            xmlns="http://www.w3.org/2000/svg"
          >
            <filter id="noise">
              <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" stitchTiles="stitch" />
            </filter>
            <rect width="100%" height="100%" filter="url(#noise)" />
          </svg>

          {/* eyebrow label inside frame */}
          <span
            class="eyebrow absolute left-4 top-4 text-background/60"
            >&mdash; PORTRAIT / 2026</span
          >
          <span
            class="eyebrow absolute bottom-4 right-4 text-background/60"
            >ABUJA · NG</span
          >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap, registerGsap, prefersReducedMotion, splitChars, ScrollTrigger } from '@/lib/gsap';

  function runHero() {
    registerGsap();

    const eyebrow = document.querySelector('[data-hero-eyebrow]');
    const h1 = document.querySelector<HTMLElement>('[data-hero-h1]');
    const sub = document.querySelector('[data-hero-sub]');
    const cta = document.querySelector('[data-hero-cta]');
    const portrait = document.querySelector('[data-hero-portrait]');
    const portraitInner = document.querySelector('[data-parallax]');

    if (!h1 || !eyebrow || !sub || !cta || !portrait) return;

    if (prefersReducedMotion()) {
      [eyebrow, sub, cta, portrait].forEach((el) =>
        el.removeAttribute('data-anim-init')
      );
      return;
    }

    // Split H1 chars
    const split = splitChars(h1);

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.fromTo(
      eyebrow,
      { y: 8, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.4 }
    );

    tl.fromTo(
      split.chars,
      { yPercent: 100, opacity: 0 },
      {
        yPercent: 0,
        opacity: 1,
        duration: 0.7,
        ease: 'power4.out',
        stagger: 0.018,
      },
      0.15
    );

    tl.fromTo(
      sub,
      { y: 12, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.5 },
      0.6
    );

    tl.fromTo(
      cta,
      { y: 8, opacity: 0, scale: 0.96 },
      { y: 0, opacity: 1, scale: 1, duration: 0.45 },
      0.8
    );

    tl.fromTo(
      portrait,
      { scale: 1.04, opacity: 0 },
      { scale: 1, opacity: 1, duration: 0.9, ease: 'power2.out' },
      0.25
    );

    // Parallax on scroll
    if (portraitInner) {
      gsap.to(portraitInner, {
        yPercent: -8,
        ease: 'none',
        scrollTrigger: {
          trigger: portrait,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 0.8,
        },
      });
    }
  }

  runHero();
  document.addEventListener('astro:page-load', runHero);
</script>
